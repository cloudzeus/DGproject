// Production-ready A-Sisyphus Prisma schema
// All models fully typed with enums, relationships, and performance indexes

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ───────────────────────── ENUMS ──────────────────────────
enum UserRole {
  admin
  manager
  member
  viewer
}

enum ProjectStatus {
  planning
  active
  on_hold
  completed
  archived
}

enum TaskStatus {
  backlog
  todo
  in_progress
  review
  done
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum ActivityAction {
  created
  updated
  completed
  commented
  assigned
  moved
}

enum ActivityTargetType {
  task
  project
  comment
}

enum FileSource {
  local
  onedrive
  sharepoint
}

enum NotificationType {
  mention
  assignment
  due_soon
  comment
  status_change
  question
  answer
  approval
  ticket
}

// ─── Ticketing ────────────────────────────────────────────────────────
enum TicketStatus {
  new // παραλήφθηκε, εκκρεμεί ανάλυση
  analyzing // τρέχει LLM ανάλυση
  triaged // υπάρχει πρόταση, περιμένει admin/manager
  converted // έγινε Task — παρακολουθεί το task status
  resolved // το task ολοκληρώθηκε (done)
  closed // KB entry αποθηκεύτηκε / έκλεισε οριστικά
  rejected // spam / εκτός σκοπού
}

enum TicketCategory {
  bug
  feature
  support
  question
  billing
  other
}

enum TaskQuestionAttachmentKind {
  question
  answer
}

// Status of a single MoM email recipient — driven by Mailgun events polled
// via /v3/{domain}/events.
enum MomDeliveryStatus {
  queued
  sent
  delivered
  opened
  failed
}

// Discriminator for the User table — every user is exactly one of:
//   - employee : internal team member; linked to SoftOne USERS / PRSN
//   - customer : a person representing a customer company; linked to SoftOne CUSTOMER (TRDR)
//   - supplier : a person representing a supplier company; linked to SoftOne SUPPLIER (TRDR)
enum UserType {
  employee
  customer
  supplier
}

enum MeetingProcessingStatus {
  scheduled // calendar event + Teams meeting created from a project, transcript will exist after the meeting
  pending // legacy alias for "queued for processing" (manually-uploaded VTT path)
  processing // pulling transcript / running LLM
  ready // insights extracted successfully
  failed // error during processing — see errorMessage
}

// SoftOne sync status per record — set by softone-contacts.ts.
enum SoftOneSyncStatus {
  unsynced // never synced
  syncing // sync in flight
  synced // ok, see softoneSyncedAt
  conflict // local change conflicts with SoftOne state — needs human decision
  error // sync failed — see softoneSyncError
}

// ───────────────────────── MODELS ────────────────────────────

// Auth & User Management
model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  password           String? // Optional for OAuth users
  name               String?
  image              String?
  role               UserRole @default(member)
  azureAdId          String?  @unique
  // When true, the user signed in with a temporary password issued by an admin
  // and must change it before accessing the rest of the app.
  mustChangePassword Boolean  @default(false)

  // ─── User type & company affiliation ───────────────────────────────
  // Every user is one of three types, each mapping to a different SoftOne object.
  userType       UserType @default(employee)
  // Display name of the company this user represents (works for all 3 types):
  //   employee → "ΑΦΟΙ ΚΟΛΛΕΡΗ ΙΚΕ"  (their employer)
  //   customer → "Acme Construction"  (the client company)
  //   supplier → "Beta Materials Ltd" (the vendor company)
  companyName    String?
  // Greek tax id (Α.Φ.Μ.) of the affiliated company — required for SoftOne sync.
  companyAfm     String?
  // SoftOne tenant company id (the COMPANY value in the ERP — tenant-specific,
  // configured per environment via S1_COMPANY env var).
  softoneCompany Int?

  // ─── SoftOne primary keys per user type ────────────────────────────
  // Employees: link to SoftOne USERS.USERID and PRSN.PRSN (the salesman/person record).
  softoneUserId      Int? @unique
  softonePrsnId      Int? @unique
  // Customers: TRDR primary key in the CUSTOMER object.
  softoneCustomerId  Int? @unique
  // Suppliers: TRDR primary key in the SUPPLIER object.
  softoneSupplierId  Int? @unique
  // Optional contact/branch line numbers within their parent record.
  softoneContactLine Int? // CUSCONT/SUPCONT LINENUM if we tracked the contact row

  // ─── Sync metadata ─────────────────────────────────────────────────
  softoneSyncStatus SoftOneSyncStatus @default(unsynced)
  softoneSyncedAt   DateTime?
  softoneSyncError  String?           @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownedWorkspaces     Workspace[]              @relation("WorkspaceOwner")
  ownedProjects       Project[]                @relation("ProjectOwner")
  approverProjects    Project[]                @relation("ProjectApprover")
  projectMemberships  ProjectMember[]
  assignedTasks       TaskAssignee[]
  createdTasks        Task[]                   @relation("TaskCreator")
  comments            Comment[]
  attachments         Attachment[]
  activities          Activity[]
  notifications       Notification[]
  accounts            Account[]
  sessions            Session[]
  mentionedInComments CommentMention[]
  departments         UserDepartment[]
  questionsAsked      TaskQuestion[]           @relation("QuestionAsker")
  questionsAddressed  TaskQuestion[]           @relation("QuestionAskee")
  taskQuestionFiles   TaskQuestionAttachment[]
  taskTemplates       TaskTemplate[]           @relation("TaskTemplateCreator")
  organizedMeetings   MeetingNote[]            @relation("MeetingOrganizer")
  createdCostLines    ProjectCostLine[]        @relation("CostLineCreator")
  mailConnection      UserMailConnection?
  emailMessages       EmailMessage[]           @relation("EmailMessageUser")

  @@index([email])
  @@index([role])
  @@index([createdAt])
  @@index([userType])
  @@index([softoneCustomerId])
  @@index([softoneSupplierId])
  @@index([softoneUserId])
  @@index([softoneSyncStatus])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Workspace & Projects
model Workspace {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner      User       @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  projects   Project[]
  activities Activity[]

  @@index([ownerId])
  @@index([createdAt])
}

model Project {
  id                String        @id @default(cuid())
  workspaceId       String
  name              String
  description       String?       @db.Text
  status            ProjectStatus @default(planning)
  color             String
  icon              String
  startDate         DateTime?
  dueDate           DateTime?
  progress          Int           @default(0) // 0-100
  // Manual sort order for the projects grid / dashboard. Smaller = earlier. Ties
  // broken by updatedAt DESC. Set on drag-and-drop reorder.
  order             Int           @default(0)
  ownerId           String
  approverId        String?
  sharepointSiteUrl String?
  teamsChannelId    String?

  // ─── SoftOne PRJC mapping ──────────────────────────────────────────
  // Local identifier readable in URLs / quick search. Format: "PRJ-YYYY-NNN".
  // Generated on create; mirror of SoftOne's PRJC.CODE when synced.
  projectCode       String?           @unique
  // SoftOne PRJC.PRJC autoinc primary key. null until first sync.
  softoneId         Int?              @unique
  // SoftOne tenant company id (per S1_COMPANY env). Allows multi-company tenants
  // to scope projects without hard-coding values.
  softoneCompany    Int?
  // Optional customer this project belongs to (PRJC.TRDR → CUSTOMER).
  // Points to a User of type=customer whose softoneCustomerId is the TRDR.
  customerUserId    String?
  // Hash of last-known synced payload — used for optimistic concurrency.
  softoneVersion    String?
  softoneSyncStatus SoftOneSyncStatus @default(unsynced)
  softoneSyncedAt   DateTime?
  softoneSyncError  String?           @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner         User              @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  approver      User?             @relation("ProjectApprover", fields: [approverId], references: [id], onDelete: SetNull)
  tasks         Task[]
  attachments   Attachment[]
  activities    Activity[]
  members       ProjectMember[]
  meetings      MeetingNote[]
  costLines     ProjectCostLine[]
  emailMessages EmailMessage[]
  ticketSources TicketSource[]    @relation("SourceDefaultProject")

  @@index([workspaceId])
  @@index([ownerId])
  @@index([approverId])
  @@index([status])
  @@index([updatedAt])
  @@index([order])
  @@index([projectCode])
  @@index([softoneId])
  @@index([softoneSyncStatus])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  role      UserRole @default(member)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

// Tasks & Assignments
model Task {
  id             String       @id @default(cuid())
  projectId      String
  title          String
  description    String?      @db.Text
  status         TaskStatus   @default(todo)
  priority       TaskPriority @default(medium)
  dueDate        DateTime?
  startDate      DateTime?
  estimatedHours Float?
  completedAt    DateTime?
  parentTaskId   String?
  order          Int          @default(0)
  outlookEventId String?
  // Per-task sync preferences chosen at creation time (and overridable on edit).
  // addToCalendar: when true and the task has a due date, sync to the creator's Outlook calendar.
  // addToTeams:    when true and the project has a teamsChannelId, post/update a card in that channel.
  addToCalendar  Boolean      @default(true)
  addToTeams     Boolean      @default(false)
  teamsMessageId String?

  // ─── AI-generated task provenance ──────────────────────────────────
  // Set when this task was auto-created from a meeting transcript.
  generatedFromMeetingId  String?
  // LLM confidence (0-1) that this action item was actually committed in the meeting.
  meetingSourceConfidence Float?
  // Verbatim quote from the transcript that supports this task.
  meetingSourceQuote      String? @db.Text
  // True when confidence was middle-tier (0.6-0.85) and a human should review
  // before this task is treated as authoritative.
  meetingNeedsReview      Boolean @default(false)

  // ─── In-progress time tracking ─────────────────────────────────────
  // Wall-clock duration the task has spent in status=in_progress. The clock
  // ticks while inProgressStartedAt is non-null; when status leaves in_progress
  // the elapsed delta is added to inProgressAccumulatedMs and the start cleared.
  // Spent time = inProgressAccumulatedMs + (status=in_progress ? now - inProgressStartedAt : 0)
  inProgressStartedAt     DateTime?
  inProgressAccumulatedMs BigInt    @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  project              Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator              User             @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  generatedFromMeeting MeetingNote?     @relation("MeetingGeneratedTask", fields: [generatedFromMeetingId], references: [id], onDelete: SetNull)
  assignees            TaskAssignee[]
  comments             Comment[]
  attachments          Attachment[]
  tags                 TaskTag[]
  activities           Activity[]
  mentionedUsers       CommentMention[] @relation("MentionedInTasks")
  questions            TaskQuestion[]
  // Tasks this task depends on (must complete before this can start)
  dependencies         TaskDependency[] @relation("TaskDependents")
  // Tasks that depend on this task (this must complete before they can start)
  dependents           TaskDependency[] @relation("TaskPrerequisites")
  emailMessages        EmailMessage[]
  ticket               Ticket?          @relation("TicketTask")

  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([dueDate])
  @@index([createdById])
  @@index([updatedAt])
  @@index([parentTaskId])
  @@index([generatedFromMeetingId])
  @@index([meetingNeedsReview])
}

model TaskAssignee {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

model TaskTag {
  id        String   @id @default(cuid())
  taskId    String
  name      String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, name])
  @@index([taskId])
  @@index([name])
}

// Comments & Interactions
model Comment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task           Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author         User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  mentionedUsers CommentMention[]

  @@index([taskId])
  @@index([authorId])
  @@index([createdAt])
}

model CommentMention {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  taskId    String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  task    Task    @relation("MentionedInTasks", fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@index([userId])
  @@index([taskId])
}

// Files & Attachments
model Attachment {
  id               String     @id @default(cuid())
  taskId           String?
  projectId        String?
  name             String
  title            String?    @db.Text
  size             Int
  mimeType         String
  url              String     @db.Text
  source           FileSource @default(local)
  sharepointFileId String?
  uploadedById     String
  createdAt        DateTime   @default(now())

  task       Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([projectId])
  @@index([uploadedById])
  @@index([source])
}

// Activity & Audit Trail
model Activity {
  id          String             @id @default(cuid())
  workspaceId String
  projectId   String?
  taskId      String?
  actorId     String
  action      ActivityAction
  targetType  ActivityTargetType
  metadata    Json? // Store additional context
  createdAt   DateTime           @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor     User      @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
  @@index([taskId])
  @@index([actorId])
  @@index([createdAt])
  @@index([action])
}

// Departments
model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  color       String   @default("#0078D4")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members UserDepartment[]

  @@index([name])
}

model UserDepartment {
  id           String   @id @default(cuid())
  userId       String
  departmentId String
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId])
  @@index([userId])
  @@index([departmentId])
}

// Reusable task definitions a user can save and pull into any project from the
// task creation form. Workspace-global (anyone authenticated can use any template);
// only the creator (or admin) can edit/delete.
model TaskTemplate {
  id             String       @id @default(cuid())
  name           String // friendly display name in the picker
  title          String // pre-fills the new task's title
  description    String?      @db.Text
  priority       TaskPriority @default(medium)
  estimatedHours Float?
  addToCalendar  Boolean      @default(true)
  addToTeams     Boolean      @default(false)
  tags           String? // comma-separated; copied verbatim into the new task
  createdById    String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  createdBy User @relation("TaskTemplateCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById])
  @@index([name])
}

// Task dependency — directed edge "task depends on dependsOn"; dependsOn must complete first.
// Project-scoped via the related tasks; cycle prevention happens in the server action.
model TaskDependency {
  id          String   @id @default(cuid())
  taskId      String
  dependsOnId String
  createdAt   DateTime @default(now())

  task      Task @relation("TaskDependents", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("TaskPrerequisites", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@index([taskId])
  @@index([dependsOnId])
}

// Task Q&A — directed questions to a specific assigned user, with optional answer
model TaskQuestion {
  id         String    @id @default(cuid())
  taskId     String
  askedById  String
  askedToId  String
  parentId   String?
  question   String    @db.Text
  answer     String?   @db.Text
  answeredAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  task        Task                     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  askedBy     User                     @relation("QuestionAsker", fields: [askedById], references: [id], onDelete: Cascade)
  askedTo     User                     @relation("QuestionAskee", fields: [askedToId], references: [id], onDelete: Cascade)
  parent      TaskQuestion?            @relation("QuestionFollowUps", fields: [parentId], references: [id], onDelete: Cascade)
  followUps   TaskQuestion[]           @relation("QuestionFollowUps")
  attachments TaskQuestionAttachment[]

  @@index([taskId])
  @@index([askedById])
  @@index([askedToId])
  @@index([parentId])
  @@index([createdAt])
}

model TaskQuestionAttachment {
  id           String                     @id @default(cuid())
  questionId   String
  uploadedById String
  kind         TaskQuestionAttachmentKind
  name         String
  title        String?                    @db.Text
  size         Int
  mimeType     String
  url          String                     @db.Text
  createdAt    DateTime                   @default(now())

  question   TaskQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  uploadedBy User         @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([uploadedById])
  @@index([kind])
}

// App-wide key/value settings (admin-managed, stored encrypted-at-rest by hosting platform)
model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Meeting transcript + LLM-extracted insights, tied to a project. Each MeetingNote
// represents one Teams meeting whose transcript was processed through our
// pseudonymization → LLM → de-pseudonymization pipeline.
model MeetingNote {
  id          String @id @default(cuid())
  projectId   String
  organizerId String // the User who scheduled / owns the meeting

  // Microsoft Teams identifiers (any of these may be null for manually-pasted VTT tests).
  // Graph IDs can exceed the default VARCHAR(191). teamsMeetingId stays bounded
  // so we can index it for duplicate detection; the other two use @db.Text.
  teamsMeetingId    String? @db.VarChar(500)
  teamsJoinUrl      String? @db.Text
  teamsTranscriptId String? @db.Text

  subject     String
  startedAt   DateTime
  endedAt     DateTime
  durationSec Int

  // Raw VTT pulled from Graph (or pasted manually for POC).
  // db.LongText so a 2-hour transcript still fits.
  transcriptVtt    String? @db.LongText
  // BunnyCDN URL of the same VTT, persisted as a file *before* LLM processing
  // so the original transcript is always recoverable even if the DB row is
  // truncated or the row is deleted.
  transcriptVttUrl String? @db.Text

  // LLM-extracted insights
  summary       String? @db.Text
  decisions     Json? // Decision[] — see lib/llm/types.ts
  actionItems   Json? // ActionItem[]
  risks         Json? // Risk[]
  openQuestions Json? // OpenQuestion[]

  // LLM call metadata (cost/audit tracking)
  llmProvider     String? // e.g. "deepseek", "azure-openai"
  llmModel        String?
  llmInputTokens  Int?
  llmOutputTokens Int?
  llmDurationMs   Int?

  // Auto-task creation summary — counts of what we generated from this meeting.
  autoTasksCreated    Int @default(0)
  autoTasksNeedReview Int @default(0)

  status       MeetingProcessingStatus @default(pending)
  errorMessage String?                 @db.Text
  processedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organizer      User          @relation("MeetingOrganizer", fields: [organizerId], references: [id], onDelete: Cascade)
  generatedTasks Task[]        @relation("MeetingGeneratedTask")
  momDeliveries  MomDelivery[]

  @@index([projectId])
  @@index([organizerId])
  @@index([status])
  @@index([createdAt])
  @@index([startedAt])
}

// Auto-ingested Teams meetings that have a transcript and/or recording but have
// NOT yet been assigned to a project for processing. The background cron writes
// rows here; super-admins browse them at /admin/meetings and promote selected
// ones to MeetingNote by assigning a project + running the LLM pipeline.
model DiscoveredMeeting {
  id                  String    @id @default(cuid())
  teamsMeetingId      String    @db.VarChar(500)
  organizerEmail      String
  organizerGraphId    String?
  subject             String?
  startedAt           DateTime?
  endedAt             DateTime?
  joinWebUrl          String?   @db.Text
  hasTranscript       Boolean   @default(false)
  hasRecording        Boolean   @default(false)
  transcriptCreatedAt DateTime?
  recordingCreatedAt  DateTime?

  // Set once promoted to a MeetingNote via admin "Assign + Process" action.
  // Stored as a plain id (not a relation) so deleting the MeetingNote keeps the
  // discovery row for audit; promotedAt makes the lifecycle inspectable.
  promotedMeetingNoteId String?
  promotedAt            DateTime?

  discoveredAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([teamsMeetingId])
  @@index([organizerEmail])
  @@index([startedAt])
  @@index([promotedMeetingNoteId])
}

// One row per (MoM email, recipient). Created when admin sends Minutes-of-Meeting
// from a MeetingNote. Updated by polling Mailgun events API for opened/delivered/failed.
model MomDelivery {
  id               String            @id @default(cuid())
  meetingNoteId    String
  recipientEmail   String
  recipientName    String?
  subject          String            @db.Text
  // Mailgun message id returned on send — used to query the events API.
  // Stored without angle brackets for direct use in `?message-id=` queries.
  mailgunMessageId String?           @db.VarChar(500)
  status           MomDeliveryStatus @default(queued)
  sentAt           DateTime?
  deliveredAt      DateTime?
  openedAt         DateTime?
  openCount        Int               @default(0)
  lastOpenedAt     DateTime?
  errorMessage     String?           @db.Text
  // Snapshot of the last Mailgun event we processed (for debugging).
  lastEventAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  meetingNote MeetingNote @relation(fields: [meetingNoteId], references: [id], onDelete: Cascade)

  @@index([meetingNoteId])
  @@index([recipientEmail])
  @@index([status])
  @@index([createdAt])
}

// Notifications
model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String           @db.Text
  type      NotificationType
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([type])
}

// ─── SoftOne catalog (products + services) ──────────────────────────────
// Local cache of SoftOne ITEM/MTRL records, synced periodically. Drives the
// admin /products + /services data tables and the per-project costing tab.
//
// Kind discriminator is derived from SoftOne's MTRTYPE smallint:
//   - 1  → product  (Είδος)
//   - 51 → service  (Υπηρεσία)
//   - anything else falls back to product so nothing is dropped from the catalog.

enum SoftoneItemKind {
  product
  service
}

model SoftoneItem {
  // Primary key mirrors SoftOne's MTRL autoinc so syncs are idempotent.
  mtrl Int @id

  code  String
  code1 String? // barcode (MTRL.CODE1)
  code2 String? // factory code (MTRL.CODE2)
  name  String  @db.Text
  name1 String? @db.Text

  kind    SoftoneItemKind
  mtrType Int // raw MTRTYPE for reference / debugging

  // Default unit price used in the cost calculator. PRICEW (χονδρικής) per user
  // preference; we also keep retail for visibility.
  unitPrice      Float  @default(0)
  retailPrice    Float?
  wholesalePrice Float?

  vatRate Float? // resolved VAT % at sync time
  vatId   Int? // FK in SoftOne (VAT object)

  unitId   Int? // MTRUNIT1
  unitName String? // e.g. "ΤΕΜ"

  groupId   Int? // MTRGROUP
  groupName String?

  brandId   Int? // MTRMARK
  brandName String?

  manufacturerId   Int? // MTRMANFCTR
  manufacturerName String?

  isActive Boolean @default(true)
  remarks  String? @db.Text

  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  costLines ProjectCostLine[]

  @@index([kind])
  @@index([isActive])
  @@index([code])
  @@index([groupId])
  @@index([brandId])
  @@index([lastSyncedAt])
}

model ProjectCostLine {
  id              String          @id @default(cuid())
  projectId       String
  softoneItemMtrl Int
  kind            SoftoneItemKind // denormalized for fast filter/sum

  quantity Float @default(1)

  // Price snapshot at the time the line was created. Frozen so future SoftOne
  // price changes don't retroactively alter the project cost. Editable in UI
  // to allow per-project negotiation.
  unitPriceSnapshot Float
  vatRateSnapshot   Float?

  notes String? @db.Text

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  item      SoftoneItem @relation(fields: [softoneItemMtrl], references: [mtrl], onDelete: Restrict)
  createdBy User        @relation("CostLineCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([softoneItemMtrl])
  @@index([kind])
  @@index([createdById])
  @@index([createdAt])
}

// ─────────────── Microsoft mailbox integration ───────────────
// Stores per-user OAuth state for Microsoft Graph mail access. Decoupled from
// the NextAuth Account row so we can request Mail.Read/Mail.Send via an
// incremental-consent popup separate from the sign-in flow, and so customers
// (userType=customer) can never have one even if they sign in with Azure.
model UserMailConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  // Microsoft tenant + object id captured at consent time — used to detect
  // when a user reauthorizes under a different identity.
  msTenantId   String
  msObjectId   String
  // Tokens for delegated Graph calls. accessToken is short-lived (~1h);
  // refreshToken is what we actually rely on for long-term access.
  accessToken  String    @db.Text
  refreshToken String    @db.Text
  // Space-separated Graph scopes actually granted (may differ from requested).
  scopes       String    @db.Text
  expiresAt    DateTime
  // Last time the user opened the import UI — used to dedupe Graph search
  // (we only ask for messages received since this checkpoint by default).
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([msObjectId])
}

enum EmailMessageDirection {
  inbound
  outbound
}

enum EmailMessageStatus {
  // Inbound message matched by Graph search, awaiting user review.
  pending
  // User reviewed & we ran the LLM but no task action chosen yet.
  analyzed
  // Linked to a task (created or updated) or attached to the project only.
  applied
  // User dismissed without action.
  ignored
  // Outbound reply we sent.
  sent
  // Outbound send failed.
  failed
}

// Unified inbound/outbound mail history per project. Every row represents a
// single Outlook message that touched a project — either pulled in from the
// mailbox or sent from inside the app — so the project's "Email" tab is the
// full audit trail.
model EmailMessage {
  id                String                @id @default(cuid())
  // Graph message id is per-mailbox and not globally unique; internetMessageId
  // (RFC 5322 Message-Id header) is — we dedupe on it.
  graphMessageId    String?
  internetMessageId String?               @unique
  // Outlook conversation id — used to thread replies and to fallback-route
  // untagged responses back to the right project.
  conversationId    String?
  direction         EmailMessageDirection
  status            EmailMessageStatus    @default(pending)
  // Project is required — we never store an email that isn't routed somewhere.
  projectId         String
  // Optional task association (created or updated by the ingest).
  taskId            String?
  // The user who imported (inbound) or sent (outbound) this message. For
  // inbound the mailbox owner = this user; for outbound it's the sender.
  userId            String
  subject           String                @db.Text
  fromAddress       String
  toAddresses       String                @db.Text // comma-joined
  ccAddresses       String?               @db.Text
  bodyHtml          String?               @db.LongText
  bodyPreview       String?               @db.Text
  receivedAt        DateTime?
  sentAt            DateTime?
  // LLM analysis output kept as raw JSON so we can re-render the proposed
  // action in the review UI or audit a bad decision later.
  llmAction         String?
  llmRaw            Json?
  // Free-form note when the ingest creates/updates a task — surfaces on the
  // task timeline so it's clear the change came from an email.
  appliedNote       String?               @db.Text
  ingestedAt        DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  user    User    @relation("EmailMessageUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, receivedAt])
  @@index([projectId, sentAt])
  @@index([taskId])
  @@index([userId])
  @@index([conversationId])
  @@index([status])
}

// ─── Ticketing System ─────────────────────────────────────────────────
// Central support desk: external client apps submit tickets, DeepSeek
// triages them, admins convert to Tasks. See docs/superpowers/specs/2026-07-17.

model TicketSource {
  id               String   @id @default(cuid())
  // Short project code declared in the client app's .env (TICKETING_PROJECT_CODE)
  code             String   @unique
  name             String
  // bcrypt hash of the API secret (shown once at creation)
  secretHash       String
  // JSON array of allowed origins for CORS + submission checks. Empty = allow all.
  originUrls       String   @db.Text
  defaultProjectId String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  defaultProject Project? @relation("SourceDefaultProject", fields: [defaultProjectId], references: [id], onDelete: SetNull)
  tickets        Ticket[]

  @@index([active])
}

model Ticket {
  id            String       @id @default(cuid())
  code          String       @unique // TKT-YYYY-NNNN
  sourceId      String
  reporterEmail String
  reporterName  String?
  originUrl     String       @db.Text
  subject       String
  body          String       @db.Text // original user text, never overwritten
  status        TicketStatus @default(new)
  // Unguessable token for the public status page /t/{token} and email links
  publicToken   String       @unique @default(cuid())

  // ─── LLM triage output ─────────────────────────────────────────────
  aiTitle               String?
  aiDescription         String?         @db.Text // technical rewrite (Greek)
  aiCategory            TicketCategory?
  aiPriority            TaskPriority?
  aiSuggestedProjectId  String?
  aiSuggestedAssigneeId String?
  aiReasoning           String?         @db.Text
  aiConfidence          Float?
  aiError               String?         @db.Text

  // ─── Conversion ────────────────────────────────────────────────────
  taskId            String?   @unique
  resolvedAt        DateTime?
  // Human-written solution from the resolver (dialog on task completion / ticket page)
  resolutionSummary String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  source TicketSource  @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  task   Task?         @relation("TicketTask", fields: [taskId], references: [id], onDelete: SetNull)
  events TicketEvent[]

  @@index([status, createdAt])
  @@index([sourceId])
  @@index([reporterEmail])
}

model TicketEvent {
  id        String   @id @default(cuid())
  ticketId  String
  // created | analyzed | triaged | converted | task_status | emailed | kb_draft | closed | rejected | note
  type      String
  payload   String?  @db.Text // JSON details
  actorId   String? // null = system
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model KnowledgeEntry {
  id           String          @id @default(cuid())
  ticketId     String?         @unique
  taskId       String?
  projectId    String?
  // TicketSource grouping for the public help center (/help/{sourceCode})
  sourceId     String?
  title        String
  problem      String          @db.Text
  solution     String          @db.Text
  // JSON array of keyword strings — matched via FULLTEXT/LIKE during triage
  tags         String          @db.Text
  category     TicketCategory?
  // Public help-center exposure — flipped explicitly by a triager, never automatic
  isPublic     Boolean         @default(false)
  // URL slug for public articles; set when first published
  slug         String?         @unique
  approvedById String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @default(now()) @updatedAt

  @@index([projectId])
  @@index([createdAt])
  @@index([sourceId, isPublic])
}
