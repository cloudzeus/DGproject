# ==============================================================================
# A-SISYPHUS - Environment Configuration
# ==============================================================================
# Copy this file to .env.local and fill in your values
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────
# Database Configuration
# ──────────────────────────────────────────────────────────────────────────
DATABASE_URL="mysql://user:password@localhost:3306/a_sisyphus"

# ──────────────────────────────────────────────────────────────────────────
# Authentication & Authorization
# ──────────────────────────────────────────────────────────────────────────
# Generate AUTH_SECRET: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"
AUTH_REDIRECT_PROXY_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# ──────────────────────────────────────────────────────────────────────────
# Microsoft 365 Integration (MANDATORY)
# ──────────────────────────────────────────────────────────────────────────
TENANT_ID="your-tenant-id"
APPLICATION_ID="your-application-id"
OBJECT_ID="your-object-id"
CLIENT_SECRET_VALUE="your-client-secret"
CLIENT_SECRET_ID="your-secret-id"

# ──────────────────────────────────────────────────────────────────────────
# Mailgun Email Service
# ──────────────────────────────────────────────────────────────────────────
MAILGUN_API_KEY="your-mailgun-api-key"
MAILGUN_DOMAIN="your-domain.com"
MAILGUN_ENDPOINT="https://api.eu.mailgun.net"

# ──────────────────────────────────────────────────────────────────────────
# BunnyCDN Storage & CDN
# ──────────────────────────────────────────────────────────────────────────
BUNNY_ACCESS_KEY="your-bunny-access-key"
BUNNY_CDN_HOSTNAME="your-domain.b-cdn.net"
BUNNY_STORAGE_ZONE="your-storage-zone"
BUNNY_STORAGE_API_HOST="storage.bunnycdn.com"

# ──────────────────────────────────────────────────────────────────────────
# Mailbox Configuration (Optional)
# ──────────────────────────────────────────────────────────────────────────
SHARED_MAILBOX_ADDRESS="shared@yourdomain.com"
JOBS_MAILBOX_ADDRESS="jobs@yourdomain.com"
CAREERS_MAILBOX_ADDRESS="careers@yourdomain.com"
TEAMS_BOOKING_EMAILS="booking@yourdomain.com"

# ──────────────────────────────────────────────────────────────────────────
# Site Configuration
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LANGUAGE="en"
NEXT_PUBLIC_SUPPORTED_LANGUAGES="en,es,fr,de,pt,ja,zh"

# ──────────────────────────────────────────────────────────────────────────
# AI/LLM Services (Optional)
# ──────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY="your-openai-api-key"
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_API_URL="https://api.deepseek.com/v1/chat/completions"

# ──────────────────────────────────────────────────────────────────────────
# External Services (Optional)
# ──────────────────────────────────────────────────────────────────────────
CLAID_API_KEY="your-claid-api-key"
GEOCODE_API="your-geocoding-api-key"
MAPTILER_API_KEY="your-maptiler-api-key"

# ──────────────────────────────────────────────────────────────────────────
# SoftOne ERP Integration (Optional)
# ──────────────────────────────────────────────────────────────────────────
SOFTONE_USERNAME="your-softone-username"
SOFTONE_PASSWORD="your-softone-password"
SOFTONE_URL="https://your-domain.oncloud.gr"
SOFTONE_APP_ID="2000"
SOFTWARE_SERIAL="YOUR-SERIAL-CODE"
SOFTWARE_COMPANY_VENTOR="Your Company Name"
SOFTWARE_COMPANY_BUYER="Buyer Company Name"

# ──────────────────────────────────────────────────────────────────────────
# Node Configuration
# ──────────────────────────────────────────────────────────────────────────
NIXPACKS_NODE_VERSION=22
NODE_ENV=development

# ==============================================================================
# IMPORTANT SECURITY NOTES:
# ==============================================================================
# 1. NEVER commit .env.local to version control
# 2. Keep all secrets secure and rotate regularly
# 3. Use strong, unique values for all SECRET keys
# 4. Different values for development, staging, and production
# 5. Use your hosting provider's secrets management in production
# 6. Regularly audit and update API keys
#
# REQUIRED SERVICES:
# - MySQL 8.0+ database
# - BunnyCDN account for file storage (MANDATORY)
# - Mailgun account for email delivery
# - Microsoft 365 tenant for authentication (MANDATORY)
# - Auth.js configured and running
#
# OPTIONAL SERVICES:
# - OpenAI for AI features
# - DeepSeek for alternative LLM
# - SoftOne ERP integration
# - GeoCoding and MapTiler for location services
#
# ==============================================================================

